# ── Datastores ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/mercury
REDIS_URL=redis://localhost:6379

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=3000

# ── ML service (separate repo) ────────────────────────────────────────────────
ML_SERVICE_URL=http://localhost:8000

# ── Translation fallback (Gemini) ─────────────────────────────────────────────
# Used when own model confidence < MIN_TRANSLATION_CONFIDENCE.
# Leave unset to disable Gemini fallback entirely (own model must handle all).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash
MIN_TRANSLATION_CONFIDENCE=0.7

# ── Message broker ────────────────────────────────────────────────────────────
# BROKER=bullmq          # default — uses Redis queues above
# BROKER=kafka           # set to kafka + uncomment KafkaBroker in broker.ts plugin
# KAFKA_BROKERS=localhost:9092

# ── Workflow runner ───────────────────────────────────────────────────────────
# WORKFLOW_RUNNER=bullmq     # default
# WORKFLOW_RUNNER=temporal   # set + uncomment TemporalWorkflowRunner in worker/index.ts
# TEMPORAL_ADDRESS=localhost:7233
